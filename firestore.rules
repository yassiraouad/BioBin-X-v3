// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Classes: teachers can create and manage, students can read their own
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.teacherId;
    }

    // Waste logs: users can create their own, read own logs, teachers can read class logs
    match /waste_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // Schools, groups, bins, quizzes, challenges, etc - authenticated access
    match /schools/{schoolId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    match /bins/{binId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    match /quizzes/{quizId} {
      allow read, create, update: if request.auth != null;
    }
    match /challenges/{challengeId} {
      allow read, create, update: if request.auth != null;
    }
    match /schools/{schoolId}/groups/{groupId} {
      allow read, create, update: if request.auth != null;
    }
    match /notifications/{userId}/items/{itemId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
    }
    match /meta/{docId} {
      allow read, create, update: if request.auth != null;
    }
    match /activityFeed/{activityId} {
      allow read, create: if request.auth != null;
    }
  }
}
